{%- liquid
  assign nav_blocks = section.blocks | where: 'type', 'nav_item'
  assign content_blocks = section.blocks | where: 'type', 'content_section'
  assign timeline_blocks = section.blocks | where: 'type', 'timeline_entry'
-%}

<section
  id="GuideArticle-{{ section.id }}"
  class="guide-article section-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} Hero {%- endcomment -%}
  <div class="guide-article__hero">
    <div class="guide-article__hero-media">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 2400
          | image_tag:
            class: 'guide-article__hero-image',
            loading: 'eager',
            widths: '750, 1100, 1500, 2000, 2400',
            sizes: '100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'guide-article__hero-placeholder' }}
      {%- endif -%}
    </div>
    <div class="guide-article__hero-overlay"></div>
    <div class="guide-article__hero-content page-width">
      {%- if section.settings.badge_number != blank -%}
        <span class="guide-article__hero-badge">{{ section.settings.badge_number }}</span>
      {%- endif -%}
      {%- if section.settings.hero_title != blank -%}
        <h1 class="guide-article__hero-title">{{ section.settings.hero_title }}</h1>
      {%- endif -%}
      {%- if section.settings.hero_subtitle != blank -%}
        <p class="guide-article__hero-subtitle">{{ section.settings.hero_subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Two-column body {%- endcomment -%}
  <div class="guide-article__body page-width">
    <div class="guide-article__layout">
      {%- comment -%} Sidebar {%- endcomment -%}
      <aside class="guide-article__sidebar">
        {%- if nav_blocks.size > 0 -%}
          <nav class="guide-article__nav" aria-label="{{ section.settings.nav_aria_label | escape }}">
            <ol class="guide-article__nav-list">
              {%- for block in nav_blocks -%}
                <li
                  class="guide-article__nav-item{% if block.settings.is_active %} is-active{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}">
                      <span class="guide-article__nav-index">{{ forloop.index }}.</span>
                      {{ block.settings.title }}
                    </a>
                  {%- else -%}
                    <span>
                      <span class="guide-article__nav-index">{{ forloop.index }}.</span>
                      {{ block.settings.title }}
                    </span>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ol>
          </nav>
        {%- endif -%}

        {%- if section.settings.show_quote and section.settings.quote_text != blank -%}
          <blockquote class="guide-article__quote">
            <span class="guide-article__quote-mark" aria-hidden="true">&ldquo;</span>
            <p class="guide-article__quote-text">{{ section.settings.quote_text }}</p>
            <span class="guide-article__quote-mark guide-article__quote-mark--bottom" aria-hidden="true">&rdquo;</span>
            {%- if section.settings.quote_author != blank -%}
              <footer class="guide-article__quote-footer">
                <cite class="guide-article__quote-author">{{ section.settings.quote_author }}</cite>
                {%- if section.settings.quote_author_title != blank -%}
                  <p class="guide-article__quote-role">{{ section.settings.quote_author_title }}</p>
                {%- endif -%}
              </footer>
            {%- endif -%}
          </blockquote>
        {%- endif -%}

        {%- if section.settings.show_back_to_top -%}
          <a href="#GuideArticle-{{ section.id }}" class="guide-article__back-top">
            <span class="guide-article__back-top-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 11V3M7 3L3.5 6.5M7 3L10.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {{ section.settings.back_to_top_label }}
          </a>
        {%- endif -%}
      </aside>

      {%- comment -%} Main content {%- endcomment -%}
      <div class="guide-article__main">
        {%- for block in content_blocks -%}
          <article class="guide-article__section" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="guide-article__section-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="guide-article__section-body rte">{{ block.settings.content }}</div>
            {%- endif -%}
          </article>
        {%- endfor -%}

        {%- if timeline_blocks.size > 0 -%}
          <div class="guide-article__timeline">
            {%- if section.settings.timeline_title != blank -%}
              <h2 class="guide-article__timeline-title">{{ section.settings.timeline_title }}</h2>
            {%- endif -%}

            <ol class="guide-article__timeline-list">
              {%- for block in timeline_blocks -%}
                <li class="guide-article__timeline-item" {{ block.shopify_attributes }}>
                  <div class="guide-article__timeline-marker">
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 120
                        | image_tag:
                          class: 'guide-article__timeline-thumb',
                          loading: 'lazy',
                          widths: '60, 80, 120',
                          sizes: '60px'
                      }}
                    {%- else -%}
                      <span class="guide-article__timeline-thumb guide-article__timeline-thumb--placeholder"></span>
                    {%- endif -%}
                  </div>

                  <div class="guide-article__timeline-content">
                    {%- if block.settings.period != blank -%}
                      <h3 class="guide-article__timeline-period">{{ block.settings.period }}</h3>
                    {%- endif -%}

                    {%- if block.settings.happening_text != blank -%}
                      <div class="guide-article__timeline-detail">
                        <strong>{{ block.settings.happening_label }}</strong>
                        <p>{{ block.settings.happening_text }}</p>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.vulnerable_text != blank -%}
                      <div class="guide-article__timeline-detail">
                        <strong>{{ block.settings.vulnerable_label }}</strong>
                        <p>{{ block.settings.vulnerable_text }}</p>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.supports_text != blank -%}
                      <div class="guide-article__timeline-detail">
                        <strong>{{ block.settings.supports_label }}</strong>
                        <p>{{ block.settings.supports_text }}</p>
                      </div>
                    {%- endif -%}
                  </div>
                </li>
              {%- endfor -%}
            </ol>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .guide-article {
    --guide-accent: {{ section.settings.accent_color }};
    --guide-text: {{ section.settings.text_color }};
    --guide-text-muted: {{ section.settings.muted_text_color }};
    --guide-timeline-bg: {{ section.settings.timeline_bg_color }};
    --guide-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --guide-hero-radius: {{ section.settings.hero_border_radius }}px;
    --guide-timeline-radius: {{ section.settings.timeline_border_radius }}px;
    color: var(--guide-text);
    font-family: var(--font-body-family), system-ui, sans-serif;
  }

  .guide-article__hero {
    position: relative;
    overflow: hidden;
    border-radius: 0 0 var(--guide-hero-radius) var(--guide-hero-radius);
    min-height: {{ section.settings.hero_min_height_mobile }}px;
    margin-bottom: {{ section.settings.content_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .guide-article__hero {
      min-height: {{ section.settings.hero_min_height }}px;
    }
  }

  .guide-article__hero-media,
  .guide-article__hero-image,
  .guide-article__hero-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .guide-article__hero-placeholder {
    background: #d9d5cf;
  }

  .guide-article__hero-overlay {
    position: absolute;
    inset: 0;
    background: #000;
    opacity: var(--guide-overlay);
  }

  .guide-article__hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: inherit;
    padding: 48px 20px;
    color: #fff;
  }

  .guide-article__hero-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 2px solid rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .guide-article__hero-title {
    margin: 0 0 12px;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .guide-article__hero-subtitle {
    margin: 0;
    max-width: 560px;
    font-size: clamp(14px, 2vw, 17px);
    line-height: 1.5;
    opacity: 0.92;
  }

  .guide-article__body {
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .guide-article__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media screen and (min-width: 990px) {
    .guide-article__layout {
      grid-template-columns: minmax(0, {{ section.settings.sidebar_width }}%) minmax(0, 1fr);
      gap: 48px;
      align-items: start;
    }
  }

  .guide-article__nav-list {
    list-style: none;
    margin: 0 0 40px;
    padding: 0;
  }

  .guide-article__nav-item {
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.45;
    color: var(--guide-text-muted);
  }

  .guide-article__nav-item a,
  .guide-article__nav-item > span {
    color: inherit;
    text-decoration: none;
    display: inline-block;
  }

  .guide-article__nav-item a:hover {
    color: var(--guide-text);
  }

  .guide-article__nav-item.is-active,
  .guide-article__nav-item.is-active a {
    color: var(--guide-text);
    font-weight: 600;
  }

  .guide-article__nav-index {
    margin-right: 2px;
  }

  .guide-article__quote {
    margin: 0 0 40px;
    padding: 0;
    border: none;
    position: relative;
  }

  .guide-article__quote-mark {
    display: block;
    font-size: 56px;
    line-height: 0.6;
    color: #d4e8ef;
    font-family: Georgia, serif;
    pointer-events: none;
  }

  .guide-article__quote-mark--bottom {
    text-align: right;
    margin-top: 4px;
  }

  .guide-article__quote-text {
    margin: 8px 0 16px;
    font-size: 15px;
    line-height: 1.65;
    font-style: italic;
    color: var(--guide-accent);
  }

  .guide-article__quote-author {
    display: block;
    font-style: normal;
    font-weight: 700;
    font-size: 14px;
    color: var(--guide-text);
    margin-bottom: 4px;
  }

  .guide-article__quote-role {
    margin: 0;
    font-size: 13px;
    line-height: 1.45;
    color: var(--guide-text-muted);
  }

  .guide-article__back-top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--guide-accent);
    text-decoration: none;
  }

  .guide-article__back-top-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(91, 163, 186, 0.12);
  }

  .guide-article__back-top:hover {
    opacity: 0.8;
  }

  .guide-article__section {
    margin-bottom: 32px;
  }

  .guide-article__section-heading {
    margin: 0 0 14px;
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 700;
    line-height: 1.3;
    color: var(--guide-text);
  }

  .guide-article__section-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--guide-text);
  }

  .guide-article__section-body p {
    margin: 0 0 14px;
  }

  .guide-article__section-body p:last-child {
    margin-bottom: 0;
  }

  .guide-article__timeline {
    margin-top: 8px;
    padding: 28px 24px 32px;
    background: var(--guide-timeline-bg);
    border-radius: var(--guide-timeline-radius);
  }

  .guide-article__timeline-title {
    margin: 0 0 28px;
    font-size: clamp(18px, 2.2vw, 22px);
    font-weight: 700;
    line-height: 1.3;
  }

  .guide-article__timeline-list {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .guide-article__timeline-list::before {
    content: '';
    position: absolute;
    left: 29px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: #d8d4ce;
  }

  .guide-article__timeline-item {
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr);
    gap: 16px;
    position: relative;
    padding-bottom: 28px;
  }

  .guide-article__timeline-item:last-child {
    padding-bottom: 0;
  }

  .guide-article__timeline-marker {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    padding-top: 4px;
  }

  .guide-article__timeline-thumb {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    background: #fff;
  }

  .guide-article__timeline-thumb--placeholder {
    display: block;
    background: #e8e4de;
  }

  .guide-article__timeline-period {
    margin: 0 0 14px;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
  }

  .guide-article__timeline-detail {
    margin-bottom: 12px;
    font-size: 14px;
    line-height: 1.6;
  }

  .guide-article__timeline-detail:last-child {
    margin-bottom: 0;
  }

  .guide-article__timeline-detail strong {
    display: block;
    margin-bottom: 4px;
    font-weight: 700;
    font-size: 13px;
  }

  .guide-article__timeline-detail p {
    margin: 0;
    color: var(--guide-text);
  }

  @media screen and (max-width: 989px) {
    .guide-article__sidebar {
      order: -1;
    }

    .guide-article__nav-list {
      margin-bottom: 24px;
    }

    .guide-article__quote {
      margin-bottom: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    .guide-article__hero-content {
      padding: 36px 16px;
    }

    .guide-article__timeline {
      padding: 20px 16px 24px;
    }

    .guide-article__timeline-list::before {
      left: 25px;
    }

    .guide-article__timeline-item {
      grid-template-columns: 50px minmax(0, 1fr);
      gap: 12px;
    }

    .guide-article__timeline-thumb {
      width: 50px;
      height: 50px;
    }
  }
{% endstyle %}

<script>
  (function () {
    document.querySelectorAll('#GuideArticle-{{ section.id }} .guide-article__back-top').forEach(function (link) {
      link.addEventListener('click', function (event) {
        var target = document.querySelector(link.getAttribute('href'));
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Guide article",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Badge number",
      "default": "4"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "First three years"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "The first three years of life represent a critical window for skin development."
    },
    {
      "type": "range",
      "id": "hero_min_height",
      "label": "Hero min height (desktop)",
      "min": 280,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 380
    },
    {
      "type": "range",
      "id": "hero_min_height_mobile",
      "label": "Hero min height (mobile)",
      "min": 200,
      "max": 480,
      "step": 20,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "hero_border_radius",
      "label": "Hero bottom corner radius",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Sidebar quote"
    },
    {
      "type": "checkbox",
      "id": "show_quote",
      "label": "Show quote block",
      "default": true
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "text",
      "id": "quote_author",
      "label": "Author name",
      "default": "Shelly Ann Winokur"
    },
    {
      "type": "textarea",
      "id": "quote_author_title",
      "label": "Author title / description",
      "default": "PhD, Molecular & Cell Biology\nAuthor of The Symbiont Factor"
    },
    {
      "type": "header",
      "content": "Sidebar navigation"
    },
    {
      "type": "text",
      "id": "nav_aria_label",
      "label": "Navigation aria label",
      "default": "Article sections"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show back to top link",
      "default": true
    },
    {
      "type": "text",
      "id": "back_to_top_label",
      "label": "Back to top label",
      "default": "Back to top"
    },
    {
      "type": "header",
      "content": "Timeline"
    },
    {
      "type": "text",
      "id": "timeline_title",
      "label": "Timeline box title",
      "default": "Microbiome & Skin Development Timeline"
    },
    {
      "type": "range",
      "id": "timeline_border_radius",
      "label": "Timeline box corner radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout & colors"
    },
    {
      "type": "range",
      "id": "sidebar_width",
      "label": "Sidebar width (desktop)",
      "min": 22,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 28
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#5ba3ba"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3d3935"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text color",
      "default": "#9a9590"
    },
    {
      "type": "color",
      "id": "timeline_bg_color",
      "label": "Timeline background",
      "default": "#f5f3f0"
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Space below hero",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Navigation item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Section title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Highlight as current section",
          "default": false
        }
      ]
    },
    {
      "type": "content_section",
      "name": "Content section",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add your body copy here. Use multiple paragraphs as needed.</p>"
        }
      ]
    },
    {
      "type": "timeline_entry",
      "name": "Timeline entry",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail image"
        },
        {
          "type": "text",
          "id": "period",
          "label": "Time period",
          "default": "Birth – first weeks"
        },
        {
          "type": "text",
          "id": "happening_label",
          "label": "Label: what's happening",
          "default": "What's happening in the skin"
        },
        {
          "type": "textarea",
          "id": "happening_text",
          "label": "Text: what's happening",
          "default": "Describe skin development during this period."
        },
        {
          "type": "text",
          "id": "vulnerable_label",
          "label": "Label: vulnerability",
          "default": "Why skin is vulnerable"
        },
        {
          "type": "textarea",
          "id": "vulnerable_text",
          "label": "Text: vulnerability",
          "default": "Explain why skin is vulnerable during this period."
        },
        {
          "type": "text",
          "id": "supports_label",
          "label": "Label: best support",
          "default": "What best supports development"
        },
        {
          "type": "textarea",
          "id": "supports_text",
          "label": "Text: best support",
          "default": "Describe what best supports healthy development."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Guide article",
      "blocks": [
        {
          "type": "nav_item",
          "settings": {
            "title": "Introduction",
            "is_active": false
          }
